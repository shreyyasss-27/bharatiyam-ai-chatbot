POPPLER_PATH=C:\\Program Files\\poppler-24.02.0\\Library\\bin

# Data directories
DATA_TEXT_DIR=E:\\bharatiyamCopy\\data\\texts
DATA_PDF_DIR=E:\\bharatiyamCopy\\data\\pdfs
FAISS_DIR=E:\\bharatiyamCopy\\data\\faiss_index
