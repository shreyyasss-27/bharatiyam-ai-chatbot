# Tesseract OCR Configuration
# Windows: Download from https://github.com/UB-Mannheim/tesseract/wiki
# Set path to your Tesseract installation
TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# Poppler Configuration (required for pdf2image)
# Windows: Download from https://github.com/oschwartz10612/poppler-windows/releases/
# Set path to your Poppler bin directory
POPPLER_PATH=C:\\Program Files\\poppler-24.02.0\\Library\\bin

# Data Directory Paths (relative to project root recommended)
DATA_TEXT_DIR=data/texts
DATA_PDF_DIR=data/pdfs
FAISS_DIR=data/faiss_index

# Embedding Model
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# API Keys (replace with your actual keys)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/
DB_NAME=document_qa

# Groq Model Configuration
GROQ_MODEL=llama-3.3-70b-versatile
